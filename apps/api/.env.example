APP_NAME=Kalshi Sports Copilot API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/kalshi_sports_copilot
SPORTS_API_BASE_URL=https://www.thesportsdb.com/api/v1/json
SPORTS_API_KEY=123
KALSHI_PUBLIC_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_KEY_ID=your-kalshi-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi-demo.key
KALSHI_LIVE_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_LIVE_KEY_ID=your-production-kalshi-key-id
KALSHI_LIVE_PRIVATE_KEY_PATH=/path/to/kalshi-live.key
SIKA_OWNER_ADMIN_TOKEN=replace-with-a-long-random-owner-token
AUTO_TRADING_ENABLED=false
AUTO_TRADING_DAILY_BUDGET_CENTS=1000
AUTO_TRADING_LOCAL_TIME=10:15
AUTO_TRADING_MAX_ORDERS_PER_DAY=5
AUTO_TRADING_MARKET_SCOPE=nba_mlb_current_slate
AUTO_TRADING_ALLOW_PARLAYS=false
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-5.4-mini
DEFAULT_TIMEZONE=America/Chicago
SCHEDULER_ENABLED=true
WATCHLIST_MIN_EDGE=0.03
WATCHLIST_MIN_CONFIDENCE=0.35
LOOKBACK_DAYS=14
LOOKAHEAD_DAYS=2
FREE_PROVIDER_LOOKBACK_DAYS=5
FREE_PROVIDER_LOOKAHEAD_DAYS=2
MARKET_SNAPSHOT_RETENTION_DAYS=7
SIGNAL_SNAPSHOT_RETENTION_DAYS=7
SHADOW_INFERENCE_RETENTION_DAYS=7
RUN_RETENTION_DAYS=14
REFRESH_JOB_RETENTION_DAYS=14
PREDICTION_RETENTION_DAYS=30
