{
  "name": "@kalshi-sports-copilot/contracts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi": "./generated/api.d.ts"
  },
  "scripts": {
    "dump": "../../.venv/bin/python scripts/dump_openapi.py openapi.json",
    "generate:types": "openapi-typescript openapi.json --output generated/api.d.ts",
    "generate": "npm run dump && npm run generate:types",
    "check": "node scripts/check_drift.mjs"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
